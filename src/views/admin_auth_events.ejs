<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true, pageTitle: 'Administração · Auth Failures' }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Auth Failures</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <%- include('partials/admin_navigation', { activeTab: 'auth-failures' }) %>

      <form method="get" action="/admin/auth-failures" class="admin-filters">
        <div class="filter-field">
          <label for="cpf">CPF</label>
          <input id="cpf" name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />
        </div>
        <div class="filter-field">
          <label for="mac">MAC</label>
          <input id="mac" name="mac" value="<%= filters?.mac || '' %>" placeholder="AA:BB:CC:DD:EE:FF" />
        </div>
        <div class="filter-field">
          <label for="ip">IP</label>
          <input id="ip" name="ip" value="<%= filters?.ip || '' %>" placeholder="172.27.0.12" />
        </div>
        <div class="filter-field">
          <label for="lsid">LSID</label>
          <input id="lsid" name="lsid" value="<%= filters?.lsid || '' %>" placeholder="ID da sessão" />
        </div>
        <div class="filter-field">
          <label for="event_type">Evento</label>
          <input id="event_type" name="event_type" value="<%= filters?.event_type || '' %>" placeholder="otp_invalid" />
        </div>
        <div class="filter-field">
          <label for="from">De (data/hora)</label>
          <input id="from" name="from" type="datetime-local" value="<%= filters?.from || '' %>" />
        </div>
        <div class="filter-field">
          <label for="to">Até (data/hora)</label>
          <input id="to" name="to" type="datetime-local" value="<%= filters?.to || '' %>" />
        </div>
        <div class="filter-actions">
          <button type="submit">Filtrar</button>
        </div>
      </form>

      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Data/hora</th><th>Evento</th><th>CPF</th><th>MAC</th><th>IP</th><th>LSID</th><th>Motivo</th><th>Descrição</th>
            </tr>
          </thead>
          <tbody>
            <% (events || []).forEach((event) => { %>
              <tr>
                <td><%= event.created_at_label %></td>
                <td title="<%= event.event_type %>"><%= event.event_label %></td>
                <td><%= event.cpf || '-' %></td>
                <td><%= event.client_mac || '-' %></td>
                <td><%= event.client_ip || '-' %></td>
                <td class="truncate" title="<%= event.lsid || '-' %>"><%= event.lsid || '-' %></td>
                <td class="truncate" title="<%= event.reason_label || '-' %>"><%= event.reason_label || '-' %></td>
                <td class="truncate" title="<%= event.description_label || '-' %>"><%= event.description_label || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
