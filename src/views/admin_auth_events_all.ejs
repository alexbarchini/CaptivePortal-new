<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true, pageTitle: 'Administração · Auth Events' }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Auth Events</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <%- include('partials/admin_navigation', { activeTab: 'auth-events' }) %>

      <form method="get" action="/admin/auth-events" class="admin-filters">
        <div class="filter-field"><label for="cpf">CPF</label><input id="cpf" name="cpf" value="<%= filters?.cpf || '' %>" /></div>
        <div class="filter-field"><label for="mac">MAC</label><input id="mac" name="mac" value="<%= filters?.mac || '' %>" /></div>
        <div class="filter-field"><label for="ip">IP</label><input id="ip" name="ip" value="<%= filters?.ip || '' %>" /></div>
        <div class="filter-field"><label for="lsid">LSID</label><input id="lsid" name="lsid" value="<%= filters?.lsid || '' %>" /></div>
        <div class="filter-field"><label for="event_type">Evento</label><input id="event_type" name="event_type" value="<%= filters?.event_type || '' %>" placeholder="otp" /></div>
        <div class="filter-field"><label for="from">De (data/hora)</label><input id="from" name="from" type="datetime-local" value="<%= filters?.from || '' %>" /></div>
        <div class="filter-field"><label for="to">Até (data/hora)</label><input id="to" name="to" type="datetime-local" value="<%= filters?.to || '' %>" /></div>
        <div class="filter-field">
          <label for="page_size">Itens por página</label>
          <select id="page_size" name="page_size">
            <% (pagination?.allowedPageSizes || [10, 20, 50, 100]).forEach((size) => { %>
              <option value="<%= size %>" <%= Number(filters?.page_size || 20) === Number(size) ? 'selected' : '' %>><%= size %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-actions"><button type="submit">Filtrar</button></div>
      </form>

      <% const queryForPage = (targetPage) => {
        const params = new URLSearchParams();
        params.set('page', String(targetPage));
        params.set('page_size', String(filters?.page_size || 20));
        if (filters?.cpf) params.set('cpf', filters.cpf);
        if (filters?.mac) params.set('mac', filters.mac);
        if (filters?.ip) params.set('ip', filters.ip);
        if (filters?.lsid) params.set('lsid', filters.lsid);
        if (filters?.event_type) params.set('event_type', filters.event_type);
        if (filters?.from) params.set('from', filters.from);
        if (filters?.to) params.set('to', filters.to);
        return params.toString();
      }; %>

      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>Data/hora</th><th>Evento</th><th>CPF</th><th>MAC</th><th>IP</th><th>LSID</th><th>Motivo</th><th>Descrição</th></tr></thead>
          <tbody>
            <% (events || []).forEach((event) => { %>
              <tr>
                <td><%= event.created_at_label %></td>
                <td title="<%= event.event_type %>"><%= event.event_label %></td>
                <td><%= event.cpf || '-' %></td>
                <td><%= event.client_mac || '-' %></td>
                <td><%= event.client_ip || '-' %></td>
                <td class="truncate" title="<%= event.lsid || '-' %>"><%= event.lsid || '-' %></td>
                <td class="truncate" title="<%= event.reason_label || '-' %>"><%= event.reason_label || '-' %></td>
                <td class="truncate" title="<%= event.description_label || '-' %>"><%= event.description_label || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="admin-pagination">
        <span class="subtle">Página <strong><%= pagination?.current_page || 1 %></strong> de <strong><%= pagination?.total_pages || 1 %></strong> · Total: <strong><%= pagination?.total_count || 0 %></strong> · <strong><%= pagination?.page_size || 20 %></strong> por página</span>
        <div class="admin-pagination-links">
          <a class="pagination-btn <%= (pagination?.current_page || 1) <= 1 ? 'is-disabled' : '' %>" href="<%= (pagination?.current_page || 1) <= 1 ? '#' : '/admin/auth-events?' + queryForPage(pagination.firstPage) %>">&lt;&lt;</a>
          <a class="pagination-btn <%= (pagination?.current_page || 1) <= 1 ? 'is-disabled' : '' %>" href="<%= (pagination?.current_page || 1) <= 1 ? '#' : '/admin/auth-events?' + queryForPage(pagination.prevPage) %>">&lt;</a>
          <% (pagination?.pageWindow || [1]).forEach((pageNumber) => { %>
            <a class="pagination-btn <%= pageNumber === (pagination?.current_page || 1) ? 'is-active' : '' %>" href="/admin/auth-events?<%= queryForPage(pageNumber) %>"><%= pageNumber %></a>
          <% }) %>
          <a class="pagination-btn <%= !(pagination?.hasNextPage) ? 'is-disabled' : '' %>" href="<%= !(pagination?.hasNextPage) ? '#' : '/admin/auth-events?' + queryForPage(pagination.nextPage) %>">&gt;</a>
          <a class="pagination-btn <%= !(pagination?.hasNextPage) ? 'is-disabled' : '' %>" href="<%= !(pagination?.hasNextPage) ? '#' : '/admin/auth-events?' + queryForPage(pagination.lastPage) %>">&gt;&gt;</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
