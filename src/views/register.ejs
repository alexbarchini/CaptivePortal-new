<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <header class="header">
    <div class="logo-wrap">
      <img src="/public/trt9-logo.jpg" alt="Justiça do Trabalho TRT da 9ª Região" class="logo"/>
    </div>
  </header>
  <main class="container">
    <section class="card wide">
      <% if (error) { %><div class="alert error"><%= error %></div><% } %>
      <form method="post" action="/register" id="register-form">
        <label for="fullName">Nome completo</label>
        <input id="fullName" name="fullName" required value="<%= values.fullName || '' %>" />

        <label for="cpf">CPF</label>
        <input id="cpf" name="cpf" required placeholder="000.000.000-00" maxlength="14" value="<%= values.cpf || '' %>" />

        <label for="phone">Telefone (DDD + celular)</label>
        <input id="phone" name="phone" required placeholder="(41) 9 9999-9999" value="<%= values.phone || '' %>" />

        <label for="email">E-mail</label>
        <input id="email" name="email" required type="email" placeholder="voce@exemplo.com" value="<%= values.email || '' %>" />

        <label for="password">Senha</label>
        <input id="password" name="password" type="password" minlength="8" required />
        <small class="help-text">A senha deve ter no mínimo 8 caracteres.</small>

        <label for="confirmPassword">Confirmar senha</label>
        <input id="confirmPassword" name="confirmPassword" type="password" minlength="8" required />
        <small id="password-match-hint" class="help-text"></small>

        <label class="check"><input type="checkbox" name="accepted_terms" required /> Li e concordo com os <a href="/terms" target="_blank" rel="noopener noreferrer">Termos de Uso</a></label>
        <label class="check"><input type="checkbox" name="accepted_processing" required /> Autorizo o tratamento dos dados pessoais para fins de controle de acesso e auditoria (LGPD)</label>

        <input type="hidden" name="lsid" value="<%= lsid || '' %>" />

        <button type="submit">Cadastrar</button>
      </form>
      <p class="subtle"><a href="/portal">Voltar para login</a></p>
    </section>
  </main>

  <script>
    const cpfInput = document.getElementById('cpf');
    const phoneInput = document.getElementById('phone');
    const passwordInput = document.getElementById('password');
    const confirmPasswordInput = document.getElementById('confirmPassword');
    const passwordMatchHint = document.getElementById('password-match-hint');

    cpfInput.addEventListener('input', () => {
      const digits = cpfInput.value.replace(/\D/g, '').slice(0, 11);
      cpfInput.value = digits
        .replace(/(\d{3})(\d)/, '$1.$2')
        .replace(/(\d{3})(\d)/, '$1.$2')
        .replace(/(\d{3})(\d{1,2})$/, '$1-$2');
    });

    phoneInput.addEventListener('input', () => {
      const digits = phoneInput.value.replace(/\D/g, '').slice(0, 11);
      phoneInput.value = digits.replace(/(\d{2})(\d)/, '($1) $2').replace(/(\d{5})(\d{1,4})$/, '$1-$2');
    });

    function updatePasswordMatchHint() {
      const password = passwordInput.value;
      const confirm = confirmPasswordInput.value;
      if (!confirm) {
        passwordMatchHint.textContent = '';
        passwordMatchHint.className = 'help-text';
      } else if (password === confirm) {
        passwordMatchHint.textContent = 'As senhas estão iguais.';
        passwordMatchHint.className = 'help-text ok';
      } else {
        passwordMatchHint.textContent = 'As senhas ainda não conferem.';
        passwordMatchHint.className = 'help-text error';
      }
    }

    passwordInput.addEventListener('input', updatePasswordMatchHint);
    confirmPasswordInput.addEventListener('input', updatePasswordMatchHint);
  </script>
</body>
</html>
