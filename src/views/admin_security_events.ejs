<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true, pageTitle: 'Administração · Security Events' }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Security Events</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <%- include('partials/admin_navigation', { activeTab: 'security-events' }) %>

      <form method="get" action="/admin/security-events" class="admin-filters">
        <div class="filter-field">
          <label for="cpf">CPF</label>
          <input id="cpf" name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />
        </div>
        <div class="filter-field">
          <label for="mac">MAC</label>
          <input id="mac" name="mac" value="<%= filters?.mac || '' %>" placeholder="AA:BB:CC:DD:EE:FF" />
        </div>
        <div class="filter-field">
          <label for="ip">IP</label>
          <input id="ip" name="ip" value="<%= filters?.ip || '' %>" placeholder="172.27.0.12" />
        </div>
        <div class="filter-field">
          <label for="event_type">Tipo de evento</label>
          <input id="event_type" name="event_type" value="<%= filters?.event_type || '' %>" placeholder="sms_abuse_suspected" />
        </div>
        <div class="filter-field">
          <label for="severity">Severidade</label>
          <input id="severity" name="severity" value="<%= filters?.severity || '' %>" placeholder="high" />
        </div>
        <div class="filter-field">
          <label for="from">De (data/hora)</label>
          <input id="from" name="from" type="datetime-local" value="<%= filters?.from || '' %>" />
        </div>
        <div class="filter-field">
          <label for="to">Até (data/hora)</label>
          <input id="to" name="to" type="datetime-local" value="<%= filters?.to || '' %>" />
        </div>
        <div class="filter-field">
          <label for="page_size">Itens por página</label>
          <select id="page_size" name="page_size">
            <% (pagination?.allowedPageSizes || [10, 20, 50, 100]).forEach((size) => { %>
              <option value="<%= size %>" <%= Number(filters?.page_size || 20) === Number(size) ? 'selected' : '' %>><%= size %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field filter-status">
          <span class="filter-label">Apenas bloqueios ativos</span>
          <label class="checkbox-inline">
            <input type="checkbox" name="only_active_blocks" value="true" <%= filters?.only_active_blocks ? 'checked' : '' %> /> Sim
          </label>
        </div>
        <div class="filter-actions">
          <button type="submit">Filtrar</button>
        </div>
      </form>

      <% const queryForPage = (targetPage) => {
        const params = new URLSearchParams();
        params.set('page', String(targetPage));
        params.set('page_size', String(filters?.page_size || 20));
        if (filters?.cpf) params.set('cpf', filters.cpf);
        if (filters?.mac) params.set('mac', filters.mac);
        if (filters?.ip) params.set('ip', filters.ip);
        if (filters?.event_type) params.set('event_type', filters.event_type);
        if (filters?.severity) params.set('severity', filters.severity);
        if (filters?.from) params.set('from', filters.from);
        if (filters?.to) params.set('to', filters.to);
        if (filters?.only_active_blocks) params.set('only_active_blocks', 'true');
        return params.toString();
      }; %>

      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Data/hora</th><th>Severidade</th><th>Tipo</th><th>Descrição</th><th>Motivo</th><th>CPF</th><th>MAC</th><th>IP</th><th>Tentativas</th><th>Janela</th><th>Bloqueado até</th><th>Contexto</th>
            </tr>
          </thead>
          <tbody>
            <% (events || []).forEach((event) => { %>
              <% const isCpf = event.correlation_type === 'cpf'; %>
              <% const isMac = event.correlation_type === 'mac'; %>
              <% const isIp = event.correlation_type === 'ip'; %>
              <tr>
                <td><%= event.created_at_label %></td>
                <td><%= event.severity %></td>
                <td title="<%= event.event_type %>"><%= event.event_label %></td>
                <td class="truncate" title="<%= event.description_label || '-' %>"><%= event.description_label || '-' %></td>
                <td class="truncate" title="<%= event.reason_label || '-' %>"><%= event.reason_label || '-' %></td>
                <td><%= isCpf ? event.correlation_value : (event.details_json?.cpf || '-') %></td>
                <td><%= isMac ? event.correlation_value : (event.details_json?.client_mac || '-') %></td>
                <td><%= isIp ? event.correlation_value : (event.details_json?.client_ip || '-') %></td>
                <td><%= event.attempt_count || '-' %></td>
                <td><%= event.window_seconds || '-' %></td>
                <td><%= event.blocked_until_label || '-' %></td>
                <td class="truncate" title="<%= JSON.stringify(event.details_json || {}) %>"><%= JSON.stringify(event.details_json || {}) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="admin-pagination">
        <span class="subtle">Página <strong><%= pagination?.current_page || 1 %></strong> de <strong><%= pagination?.total_pages || 1 %></strong> · Total: <strong><%= pagination?.total_count || 0 %></strong> · <strong><%= pagination?.page_size || 20 %></strong> por página</span>
        <div class="admin-pagination-links">
          <a class="pagination-btn <%= (pagination?.current_page || 1) <= 1 ? 'is-disabled' : '' %>" href="<%= (pagination?.current_page || 1) <= 1 ? '#' : '/admin/security-events?' + queryForPage(pagination.firstPage) %>">&lt;&lt;</a>
          <a class="pagination-btn <%= (pagination?.current_page || 1) <= 1 ? 'is-disabled' : '' %>" href="<%= (pagination?.current_page || 1) <= 1 ? '#' : '/admin/security-events?' + queryForPage(pagination.prevPage) %>">&lt;</a>
          <% (pagination?.pageWindow || [1]).forEach((pageNumber) => { %>
            <a class="pagination-btn <%= pageNumber === (pagination?.current_page || 1) ? 'is-active' : '' %>" href="/admin/security-events?<%= queryForPage(pageNumber) %>"><%= pageNumber %></a>
          <% }) %>
          <a class="pagination-btn <%= !(pagination?.hasNextPage) ? 'is-disabled' : '' %>" href="<%= !(pagination?.hasNextPage) ? '#' : '/admin/security-events?' + queryForPage(pagination.nextPage) %>">&gt;</a>
          <a class="pagination-btn <%= !(pagination?.hasNextPage) ? 'is-disabled' : '' %>" href="<%= !(pagination?.hasNextPage) ? '#' : '/admin/security-events?' + queryForPage(pagination.lastPage) %>">&gt;&gt;</a>
        </div>
      </div>
    </section>
  </main>
  <script>
    (() => {
      const filterForm = document.querySelector('.admin-filters');
      const pageSizeSelect = document.querySelector('#page_size');
      if (!filterForm || !pageSizeSelect) return;

      pageSizeSelect.addEventListener('change', () => {
        const pageInput = filterForm.querySelector('input[name="page"]');
        if (pageInput) {
          pageInput.value = '1';
        } else {
          const hiddenPageInput = document.createElement('input');
          hiddenPageInput.type = 'hidden';
          hiddenPageInput.name = 'page';
          hiddenPageInput.value = '1';
          filterForm.appendChild(hiddenPageInput);
        }
        filterForm.submit();
      });
    })();
  </script>
</body>
</html>
