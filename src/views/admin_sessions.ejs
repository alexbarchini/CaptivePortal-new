<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true, pageTitle: 'Administração · Sessões' }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Consulta administrativa</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>

      <form method="get" action="/admin/sessions" class="admin-filters">
        <div class="filter-field">
          <label for="cpf">CPF</label>
          <input id="cpf" name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />
        </div>

        <div class="filter-field">
          <label for="name">Nome (parcial)</label>
          <input id="name" name="name" value="<%= filters?.name || '' %>" placeholder="Ex.: Maria" />
        </div>

        <div class="filter-field">
          <label for="from">De (data/hora)</label>
          <input id="from" name="from" type="datetime-local" value="<%= filters?.from || '' %>" />
        </div>

        <div class="filter-field">
          <label for="to">Até (data/hora)</label>
          <input id="to" name="to" type="datetime-local" value="<%= filters?.to || '' %>" />
        </div>

        <div class="filter-actions">
          <button type="submit">Pesquisar</button>
        </div>
      </form>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (!error) { %>
        <h3>Sessões recentes (até 50 por página)</h3>
        <% if (!sessions || sessions.length === 0) { %>
          <div class="alert">Nenhum resultado encontrado para os filtros informados.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th class="col-lsid">LSID</th>
                  <th class="col-cpf">CPF</th>
                  <th class="col-name">Nome</th>
                  <th class="col-created">Criada em</th>
                  <th class="col-authorized">Autorizada em</th>
                  <th class="col-consumed">Consumida em</th>
                  <th class="col-duration">Duração</th>
                  <th class="col-status">Status</th>
                  <th class="col-ip">IP</th>
                  <th class="col-mac">MAC</th>
                  <th class="col-ssid">SSID</th>
                  <th class="col-vlan">VLAN</th>
                  <th class="col-apip">AP IP</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach((session) => { %>
                  <tr>
                    <td class="truncate" title="<%= session.lsid %>"><%= session.lsid %></td>
                    <td><%= session.cpf_formatado || session.cpf_normalizado || '-' %></td>
                    <td class="truncate" title="<%= session.nome || '-' %>"><%= session.nome || '-' %></td>
                    <td><%= session.created_at ? new Date(session.created_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.authorized_at ? new Date(session.authorized_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.consumed_at ? new Date(session.consumed_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.duration_hms || '-' %></td>
                    <td><span class="status-pill status-<%= String(session.status || '').toLowerCase() %>"><%= session.status %></span></td>
                    <td><%= session.uip || '-' %></td>
                    <td><%= session.client_mac || '-' %></td>
                    <td><%= session.ssid || '-' %></td>
                    <td><%= session.vlan || '-' %></td>
                    <td><%= session.apip || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="admin-pagination">
            <span class="subtle">Offset atual: <strong><%= pagination?.offset || 0 %></strong></span>
            <% if (pagination?.hasNextPage) { %>
              <a class="next-page" href="/admin/sessions?cpf=<%= encodeURIComponent(filters?.cpf || '') %>&name=<%= encodeURIComponent(filters?.name || '') %>&from=<%= encodeURIComponent(filters?.from || '') %>&to=<%= encodeURIComponent(filters?.to || '') %>&offset=<%= pagination?.nextOffset || 50 %>">Próxima página</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </section>
  </main>
</body>
</html>
