<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true, pageTitle: 'Administração · Sessões' }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Consulta administrativa</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <p class="subtle"><a href="/admin/auth-events">Auth events</a> · <a href="/admin/security-events">Security events</a></p>

      <form method="get" action="/admin/sessions" class="admin-filters">
        <div class="filter-field">
          <label for="cpf">CPF</label>
          <input id="cpf" name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />
        </div>

        <div class="filter-field">
          <label for="name">Nome (parcial)</label>
          <input id="name" name="name" value="<%= filters?.name || '' %>" placeholder="Ex.: Maria" />
        </div>

        <div class="filter-field">
          <label for="mac">MAC do cliente</label>
          <input id="mac" name="mac" value="<%= filters?.mac || '' %>" placeholder="AA:BB:CC:DD:EE:FF" />
        </div>

        <div class="filter-field">
          <label for="ip">IP do cliente</label>
          <input id="ip" name="ip" value="<%= filters?.ip || '' %>" placeholder="172.27.0.12" />
        </div>

        <div class="filter-field">
          <label for="from">De (data/hora)</label>
          <input id="from" name="from" type="datetime-local" value="<%= filters?.from || '' %>" />
        </div>

        <div class="filter-field">
          <label for="to">Até (data/hora)</label>
          <input id="to" name="to" type="datetime-local" value="<%= filters?.to || '' %>" />
        </div>

        <div class="filter-field filter-status">
          <span class="filter-label">Status</span>
          <label class="checkbox-inline">
            <input type="checkbox" name="status" value="pending" <%= (filters?.status || []).includes('pending') ? 'checked' : '' %> /> PENDING
          </label>
          <label class="checkbox-inline">
            <input type="checkbox" name="status" value="open" <%= (filters?.status || []).includes('open') ? 'checked' : '' %> /> OPEN
          </label>
          <label class="checkbox-inline">
            <input type="checkbox" name="status" value="closed" <%= (filters?.status || []).includes('closed') ? 'checked' : '' %> /> CLOSED
          </label>
        </div>

        <div class="filter-actions">
          <button type="submit">Pesquisar</button>
        </div>
      </form>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (!error) { %>
        <h3>Sessões recentes (até 50 por página)</h3>
        <% if (!sessions || sessions.length === 0) { %>
          <div class="alert">Nenhum resultado encontrado para os filtros informados.</div>
        <% } else { %>
          <div class="table-scroll-top" data-top-scrollbar hidden>
            <div class="table-scroll-top-inner" data-top-scrollbar-inner></div>
          </div>
          <div class="table-wrap" data-table-wrap>
            <table class="admin-table" data-admin-table>
              <thead>
                <tr>
                  <th class="col-lsid">LSID</th>
                  <th class="col-cpf">CPF</th>
                  <th class="col-name">Nome</th>
                  <th class="col-created">Criada em</th>
                  <th class="col-authorized">Autorizada em</th>
                  <th class="col-duration">Duração</th>
                  <th class="col-status">Status</th>
                  <th class="col-ip">IP cliente</th>
                  <th class="col-mac">MAC</th>
                  <th class="col-vlan">VLAN</th>
                  <th class="col-apip">AP IP</th>
                  <th>Dispositivo</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach((session) => { %>
                  <tr>
                    <td class="truncate" title="<%= session.lsid %>"><%= session.lsid %></td>
                    <td><%= session.cpf_formatado || session.cpf_normalizado || '-' %></td>
                    <td class="truncate" title="<%= session.nome || '-' %>"><%= session.nome || '-' %></td>
                    <td><span title="<%= session.created_at_label %>"><%= session.created_at_label %></span></td>
                    <td><span title="<%= session.authorized_at_label %>"><%= session.authorized_at_label %></span></td>
                    <td><%= session.duration_hms || '-' %></td>
                    <td><span class="status-pill status-<%= String(session.status || '').toLowerCase() %>"><%= session.status %></span></td>
                    <td class="truncate" title="<%= session.uip || '-' %>"><%= session.uip || '-' %></td>
                    <td class="truncate" title="<%= session.client_mac || '-' %>"><%= session.client_mac || '-' %></td>
                    <td><%= session.vlan || '-' %></td>
                    <td class="truncate" title="<%= session.apip || '-' %>"><%= session.apip || '-' %></td>
                    <td class="truncate" title="<%= session.device_display_name %>"><%= session.device_display_name %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="admin-pagination">
            <span class="subtle">Offset atual: <strong><%= pagination?.offset || 0 %></strong></span>
            <% if (pagination?.hasNextPage) { %>
              <a class="next-page" href="/admin/sessions?cpf=<%= encodeURIComponent(filters?.cpf || '') %>&name=<%= encodeURIComponent(filters?.name || '') %>&mac=<%= encodeURIComponent(filters?.mac || '') %>&ip=<%= encodeURIComponent(filters?.ip || '') %>&from=<%= encodeURIComponent(filters?.from || '') %>&to=<%= encodeURIComponent(filters?.to || '') %><% (filters?.status || []).forEach((status) => { %>&status=<%= encodeURIComponent(status) %><% }) %>&offset=<%= pagination?.nextOffset || 50 %>">Próxima página</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </section>
  </main>
  <script>
    (() => {

      const filterForm = document.querySelector('.admin-filters');
      const statusCheckboxes = filterForm ? filterForm.querySelectorAll('input[name="status"]') : [];
      if (filterForm && statusCheckboxes.length > 0) {
        filterForm.addEventListener('submit', () => {
          const selectedCount = Array.from(statusCheckboxes).filter((checkbox) => checkbox.checked).length;
          if (selectedCount === 0) {
            statusCheckboxes.forEach((checkbox) => { checkbox.checked = true; });
          }
        });
      }

      const topScroll = document.querySelector('[data-top-scrollbar]');
      const topInner = document.querySelector('[data-top-scrollbar-inner]');
      const tableWrap = document.querySelector('[data-table-wrap]');
      const table = document.querySelector('[data-admin-table]');
      if (!topScroll || !topInner || !tableWrap || !table) return;

      let syncingFromTop = false;
      let syncingFromBottom = false;

      const syncVisibilityAndWidth = () => {
        const wrapWidth = tableWrap.clientWidth;
        const tableWidth = table.scrollWidth;
        topInner.style.width = `${tableWidth}px`;
        const shouldShow = tableWidth > wrapWidth + 1;
        topScroll.hidden = !shouldShow;
        if (!shouldShow) {
          topScroll.scrollLeft = 0;
          tableWrap.scrollLeft = 0;
        } else {
          topScroll.scrollLeft = tableWrap.scrollLeft;
        }
      };

      topScroll.addEventListener('scroll', () => {
        if (syncingFromBottom) return;
        syncingFromTop = true;
        tableWrap.scrollLeft = topScroll.scrollLeft;
        syncingFromTop = false;
      });

      tableWrap.addEventListener('scroll', () => {
        if (syncingFromTop) return;
        syncingFromBottom = true;
        topScroll.scrollLeft = tableWrap.scrollLeft;
        syncingFromBottom = false;
      });

      window.addEventListener('resize', syncVisibilityAndWidth);
      if (window.ResizeObserver) {
        const observer = new ResizeObserver(syncVisibilityAndWidth);
        observer.observe(tableWrap);
        observer.observe(table);
      }
      syncVisibilityAndWidth();
    })();
  </script>
</body>
</html>
