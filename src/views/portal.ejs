<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <header class="header">
    <div class="logo-wrap">
      <img src="/public/trt9-logo.jpg" alt="Justiça do Trabalho TRT da 9ª Região" class="logo"/>
    </div>
  </header>
  <main class="container">
    <section class="card">
      <h2>Entrar no Wi-Fi de visitantes</h2>
      <% if (error) { %><div class="alert error"><%= error %></div><% } %>
      <% if (message) { %><div class="alert ok"><%= message %></div><% } %>
      <form method="post" action="/login">
        <label>CPF</label>
        <input name="cpf" required placeholder="000.000.000-00" />

        <label>Senha</label>
        <input name="password" type="password" required />

        <input type="hidden" name="lsid" value="<%= lsid || '' %>" />

        <button type="submit">Entrar</button>
      </form>
      <p class="subtle">Não possui cadastro? <a href="/register?lsid=<%= encodeURIComponent(lsid || '') %>">Criar acesso de visitante</a></p>
    </section>
  </main>
</body>
</html>
