<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%- include('partials/admin_header', { showLogout: true }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Painel administrativo</h2>
      <p class="subtle">Logado como <strong><%= adminUser %></strong></p>
      <form method="get" action="/admin/lookup">
        <label>CPF</label>
        <input name="cpf" required placeholder="000.000.000-00" />
        <button type="submit">Consultar</button>
      </form>
      <p style="margin-top: 12px;" class="subtle">
        <a href="/admin/auth-failures">Ver Auth Failures</a> ·
        <a href="/admin/security-events">Ver Security Events</a>
      </p>
    </section>
  </main>
</body>
</html>
