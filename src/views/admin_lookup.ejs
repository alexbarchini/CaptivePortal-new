<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <%
    const saoPauloFormatter = new Intl.DateTimeFormat('pt-BR', {
      timeZone: 'America/Sao_Paulo',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false
    });
    const formatDateTime = (value) => {
      if (!value) return '-';
      return saoPauloFormatter.format(new Date(value));
    };
  %>
  <%- include('partials/admin_header', { showLogout: true }) %>
  <main class="admin-shell">
    <section class="card admin-card">
      <h2>Consulta administrativa</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <p><a href="/admin">Voltar</a></p>

      <form method="get" action="/admin/lookup" class="admin-filters">
        <label>CPF</label>
        <input name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />

        <label>Nome (parcial)</label>
        <input name="name" value="<%= filters?.name || '' %>" placeholder="Ex.: Maria" />

        <label>De (data/hora)</label>
        <input name="from" type="datetime-local" value="<%= filters?.from || '' %>" />

        <label>Até (data/hora)</label>
        <input name="to" type="datetime-local" value="<%= filters?.to || '' %>" />

        <button type="submit">Pesquisar</button>
      </form>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (!error) { %>
        <h3>Sessões recentes (até 50 por página)</h3>
        <% if (!sessions || sessions.length === 0) { %>
          <div class="alert">Nenhum resultado encontrado para os filtros informados.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th class="col-lsid">LSID</th>
                  <th class="col-cpf">CPF</th>
                  <th class="col-name">Nome</th>
                  <th class="col-created">Criada em</th>
                  <th class="col-authorized">Autorizada em</th>
                  <th class="col-duration">Duração</th>
                  <th class="col-status">Status</th>
                  <th class="col-ip">IP</th>
                  <th class="col-mac">MAC</th>
                  <th class="col-vlan">VLAN</th>
                  <th class="col-apip">AP IP</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach((session) => { %>
                  <tr>
                    <td class="truncate" title="<%= session.lsid %>"><%= session.lsid %></td>
                    <td><%= session.cpf_formatado || session.cpf_normalizado || '-' %></td>
                    <td class="truncate" title="<%= session.nome || '-' %>"><%= session.nome || '-' %></td>
                    <td><%= formatDateTime(session.created_at) %></td>
                    <td><%= formatDateTime(session.authorized_at) %></td>
                    <td><%= session.duration_hms || '-' %></td>
                    <td><%= session.status %></td>
                    <td><%= session.uip || '-' %></td>
                    <td class="truncate" title="<%= session.client_mac || '-' %>"><%= session.client_mac || '-' %></td>
                    <td><%= session.vlan || '-' %></td>
                    <td><%= session.apip || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="admin-pagination">
            <span class="subtle">Offset atual: <strong><%= pagination?.offset || 0 %></strong></span>
            <% if (pagination?.hasNextPage) { %>
              <a class="next-page" href="/admin/lookup?cpf=<%= encodeURIComponent(filters?.cpf || '') %>&name=<%= encodeURIComponent(filters?.name || '') %>&from=<%= encodeURIComponent(filters?.from || '') %>&to=<%= encodeURIComponent(filters?.to || '') %>&offset=<%= pagination?.nextOffset || 50 %>">Próxima página</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </section>
  </main>
</body>
</html>
