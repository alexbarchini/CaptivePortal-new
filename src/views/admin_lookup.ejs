<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <%- include('partials/header') %>
  <main class="container">
    <section class="card wide admin-card">
      <h2>Consulta administrativa</h2>
      <p class="subtle">Administrador: <strong><%= adminUser %></strong></p>
      <p><a href="/admin">Voltar</a></p>

      <form method="get" action="/admin/lookup" class="admin-filters">
        <label>CPF</label>
        <input name="cpf" value="<%= filters?.cpf || '' %>" placeholder="000.000.000-00" />

        <label>Nome (parcial)</label>
        <input name="name" value="<%= filters?.name || '' %>" placeholder="Ex.: Maria" />

        <label>De (data/hora)</label>
        <input name="from" type="datetime-local" value="<%= filters?.from || '' %>" />

        <label>Até (data/hora)</label>
        <input name="to" type="datetime-local" value="<%= filters?.to || '' %>" />

        <button type="submit">Pesquisar</button>
      </form>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (!error) { %>
        <h3>Sessões recentes (até 50 por página)</h3>
        <% if (!sessions || sessions.length === 0) { %>
          <div class="alert">Nenhum resultado encontrado para os filtros informados.</div>
        <% } else { %>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>LSID</th>
                  <th>Nome</th>
                  <th>CPF</th>
                  <th>Criada em</th>
                  <th>Autorizada em</th>
                  <th>Consumida em</th>
                  <th>Duração</th>
                  <th>Status</th>
                  <th>IP</th>
                  <th>MAC</th>
                  <th>SSID</th>
                  <th>VLAN</th>
                  <th>AP IP</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach((session) => { %>
                  <tr>
                    <td class="lsid-cell" title="<%= session.lsid %>"><%= session.lsid %></td>
                    <td><%= session.nome || '-' %></td>
                    <td><%= session.cpf_formatado || session.cpf_normalizado || '-' %></td>
                    <td><%= session.created_at ? new Date(session.created_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.authorized_at ? new Date(session.authorized_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.consumed_at ? new Date(session.consumed_at).toLocaleString('pt-BR') : '-' %></td>
                    <td><%= session.duration_hms || '-' %></td>
                    <td><%= session.status %></td>
                    <td><%= session.uip || '-' %></td>
                    <td><%= session.client_mac || '-' %></td>
                    <td><%= session.ssid || '-' %></td>
                    <td><%= session.vlan || '-' %></td>
                    <td><%= session.apip || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="admin-pagination">
            <span class="subtle">Offset atual: <strong><%= pagination?.offset || 0 %></strong></span>
            <% if (pagination?.hasNextPage) { %>
              <a class="next-page" href="/admin/lookup?cpf=<%= encodeURIComponent(filters?.cpf || '') %>&name=<%= encodeURIComponent(filters?.name || '') %>&from=<%= encodeURIComponent(filters?.from || '') %>&to=<%= encodeURIComponent(filters?.to || '') %>&offset=<%= pagination?.nextOffset || 50 %>">Próxima página</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </section>
  </main>
</body>
</html>
